@import "tailwindcss";
/*these are standard breakpoints, mentioned here onlyt for references, so coding becomes easier*/
@theme {

  --font-my-custom: "Kavoon", sans-serif;
  --breakpoint-sm: 640px;
  --breakpoint-md: 768px;
  --breakpoint-lg: 1024px;
  --breakpoint-Xl: 1280px;
  --breakpoint-2Xl: 1536px;
}

@layer utilities {
  .all-ut {
    font-family: "Kavoon", sans-serif;
    font-weight: 400;
    font-size: large;
  }
}
